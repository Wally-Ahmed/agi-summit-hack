{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${CODESPACES:-}\" ] && bash \"$CLAUDE_PROJECT_DIR/scripts/sync-codespace-palace.sh\" >/dev/null 2>&1; true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${CODESPACES:-}\" ] && bash \"$CLAUDE_PROJECT_DIR/scripts/sync-codespace-palace.sh\" >/dev/null 2>&1; true"
          }
        ]
      }
    ]
  }
}
